{
  "manifest_version": 3,
  "name": "ASU Class Seat Monitor",
  "version": "1.1",
  "description": "Monitor ASU class seat availability and get notified when seats open up.",
  "permissions": [
    "alarms",
    "storage",
    "notifications",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://eadvs-cscc-catalog-api.apps.asu.edu/*",
    "https://catalog.apps.asu.edu/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://catalog.apps.asu.edu/*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
